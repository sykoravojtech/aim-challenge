# Copy to .env and fill in real values. .env is gitignored.

# --- OpenAI ---
# Used for embeddings (text-embedding-3-small, 1536 dim) and gpt-4o-mini calls.
OPENAI_API_KEY=sk-...

# --- Pinecone ---
# Create a serverless index with dim=1536, metric=cosine.
PINECONE_API_KEY=...
PINECONE_INDEX=aim-chunks

# --- GCP (swap layers) ---
# Prep project from 2026-04-23 lives at europe-west3; reuse unless the recruiter
# hands you a company workspace. credentials.json should sit at repo root.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
GCP_PROJECT_ID=aim-challenge-494220
GCP_LOCATION=europe-west3
BQ_DATASET=aim_pipeline
GCS_BUCKET=aim-raw-articles
